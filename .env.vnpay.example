# Copy file nay thanh .env khi muon demo VNPAY voi ngrok chay cung Docker Compose.
# Khong commit file .env len GitHub.

# Cong mac dinh cua du an. Nen giu BACKEND_PORT=8080 vi frontend dang goi API localhost:8080.
BACKEND_PORT=8080
FRONTEND_PORT=5173

# URL frontend local.
FRONTEND_URL=http://localhost:5173

# Domain HTTPS cua ngrok tro ve backend container cong 8080.
PUBLIC_BASE_URL=https://posting-prissy-elevate.ngrok-free.dev

# Ngrok se duoc Docker Compose chay cung du an.
NGROK_AUTHTOKEN=your_ngrok_authtoken
NGROK_DOMAIN=posting-prissy-elevate.ngrok-free.dev
NGROK_DASHBOARD_PORT=4040

# VNPAY Sandbox do VNPAY cap.
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
