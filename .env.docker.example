# Copy file nay thanh .env truoc khi chay Docker Compose.

MYSQL_DATABASE=electroshop
MYSQL_ROOT_PASSWORD=root

BACKEND_PORT=8080
FRONTEND_PORT=5173

FRONTEND_URL=http://localhost:5173
PUBLIC_BASE_URL=https://posting-prissy-elevate.ngrok-free.dev

# VNPAY Sandbox
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# Ngrok chay cung Docker Compose de demo VNPAY Return URL/IPN tu internet.
# Nen dung static domain cua ngrok, vi backend can PUBLIC_BASE_URL co dinh.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=posting-prissy-elevate.ngrok-free.dev
NGROK_DASHBOARD_PORT=4040
