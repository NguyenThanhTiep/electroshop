# Copy file nay thanh .env truoc khi chay Docker Compose.

MYSQL_DATABASE=electroshop
MYSQL_ROOT_PASSWORD=root

BACKEND_PORT=8080
FRONTEND_PORT=5173

FRONTEND_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8080

# VNPAY Sandbox
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# Ngrok chi can khi demo VNPAY Return URL/IPN tu internet.
# Nen dung static domain cua ngrok, vi backend can PUBLIC_BASE_URL co dinh.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=your-domain.ngrok-free.app
NGROK_DASHBOARD_PORT=4040

# Khi bat profile ngrok, hay dat:
# PUBLIC_BASE_URL=https://your-domain.ngrok-free.app
